{
  "name": "1bit",
  "version": "0.1.0",
  "description": "NPU inference harness with Open WebUI frontend",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "esbuild src/server.ts --bundle --platform=node --outdir=dist --format=cjs --out-extension:.js=.cjs",
    "start": "node dist/server.cjs",
    "dev": "esbuild src/server.ts --bundle --platform=node --outdir=dist --format=cjs --out-extension:.js=.cjs --watch & node dist/server.cjs"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "fastify": "^5.0.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  }
}
